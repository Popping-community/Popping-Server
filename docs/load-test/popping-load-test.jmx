          <elementProp name="SERVER" elementType="Argument">
            <stringProp name="Argument.name">SERVER</stringProp>
            <stringProp name="Argument.value">popping.duckdns.org</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
